<FindBugsFilter>
    <!-- Accept expose of internal representations and mutable fields in request and response model classes
    generated by the openapi-generator -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.account.api.v0.model.*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.account.api.origin.model.*"/>
    </Match>

    <!-- Accepting generated builders to have unusual namings -->
    <Match>
        <Bug pattern="NM_METHOD_NAMING_CONVENTION"/>
        <Class name="~.*Builder"/>
    </Match>

    <!-- Accept expose of internal representations and mutable fields -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.account.domain.model.*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.account.application.model.*"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
        <Package name="se.digg.wallet.account.infrastructure.model.*"/>
    </Match>
</FindBugsFilter>
